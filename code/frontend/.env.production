# 生产构建（pnpm build）— 可提交占位；生产密钥与真实 URL 优先用 CI 注入或 .env.production.local
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0

# 后端 API 完整源（无末尾 /）；与前端不同源时需后端 CORS
 VITE_API_BASE_URL=http://36.110.89.30:8765
# 报告文件下载基地址；不填时默认使用当前前端页面 origin
 VITE_REPORT_DOWNLOAD_BASE_URL=http://36.110.89.30:8088

# 部署到生产时至少配置其一（或通过流水线注入同名变量）：
# VITE_N8N_BASE_URL=https://n8n.example.com
# VITE_N8N_WORD_REPORT_WEBHOOK_URL=https://n8n.example.com/webhook/your-uuid
