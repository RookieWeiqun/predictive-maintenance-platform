# 复制为 .env.development.local / .env.production.local 等填入密钥（这些文件已被 gitignore）
# 说明见 Readme「环境变量」与 https://vitejs.dev/guide/env-and-mode.html

# ---------- 应用（可选）----------
# VITE_APP_NAME=预防性维护报告平台
# VITE_APP_VERSION=1.0.0
# VITE_APP_ENV=development

# 设为任意非空值时加载 public/theme/dist 下品牌主题（见 src/main.ts）
# VITE_THEME=brand

# ---------- 后端 REST（OpenAPI，路径前缀 /api）----------
# 生产/预发：完整 API 源，无末尾 /
# VITE_API_BASE_URL=https://api.example.com
# 报告文件下载基地址；不填时默认使用当前前端页面 origin
# VITE_REPORT_DOWNLOAD_BASE_URL=https://app.example.com
# 开发：Vite 将 /api 代理到此目标（见 vite.config.ts）
# VITE_API_PROXY_TARGET=http://localhost:8765

# ---------- OneID 登录 ----------
# OneID code 换 token 的后端服务根地址；不填则沿用 VITE_API_BASE_URL 或同源 /api
# VITE_ONEID_API_BASE_URL=http://36.110.89.30:8765
# OneID Issuer / Authorization Endpoint 如不填则使用当前 QA 配置
# VITE_ONEID_ISSUER=
# VITE_ONEID_AUTHORIZATION_ENDPOINT=
# OneID Client ID；未配置时前端会尝试从 Issuer 最后一段推导
# VITE_ONEID_CLIENT_ID=
# VITE_ONEID_SCOPE=openid profile
# OneID 登录回调地址，默认 http(s)://当前域名/callback
# VITE_ONEID_REDIRECT_URI=http://36.110.89.30:8088/callback

# ---------- n8n / Word 导出 ----------
# 完整 Webhook URL（优先级最高）
# VITE_N8N_WORD_REPORT_WEBHOOK_URL=

# n8n 根地址，不要末尾 /（与代码内默认 webhook id 组合）
# VITE_N8N_BASE_URL=https://n8n.example.com

# 开发环境：默认 true（走 /n8n-proxy）；设为 false 则浏览器直连 n8n（需 CORS）
# VITE_N8N_DEV_PROXY=false

# dev server 代理目标（vite.config.ts）
# VITE_N8N_DEV_PROXY_TARGET=https://n8n.example.com

# Webhook 鉴权（生产密钥勿入库，用 .env.production.local）
# VITE_N8N_ENABLE_AUTH=true
# VITE_N8N_API_KEY=
# VITE_N8N_AUTH_TYPE=bearer
# VITE_N8N_AUTH_HEADER=Authorization
